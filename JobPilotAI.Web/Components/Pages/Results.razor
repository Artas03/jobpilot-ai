@page "/results"
@rendermode InteractiveServer
@using System.Globalization
@inject JobResultState ResultState

<PageTitle>Results | JobPilotAI</PageTitle>

<div class="page-heading">
    <p class="eyebrow">Job workspace</p>
    <h1>Results</h1>
    <p>Review generated summaries, invoices, follow-ups and suggested actions.</p>
</div>

@if (ResultState.Current is { } result)
{
    <div class="results-grid">
        <section class="content-panel summary-panel">
            <p class="section-label">Professional Summary</p>
            <h2>Work completed</h2>
            <p class="summary-copy">@result.ProfessionalSummary</p>
        </section>

        <section class="content-panel invoice-panel">
            <div class="invoice-heading">
                <div>
                    <p class="section-label">Invoice</p>
                    <h2>@result.Invoice.InvoiceNumber</h2>
                </div>
                <div class="invoice-total">
                    <span>Total</span>
                    <strong>@FormatCurrency(result.Invoice.Total)</strong>
                </div>
            </div>

            <div class="invoice-table-wrapper">
                <table class="invoice-table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th>Quantity</th>
                            <th>Unit price</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in result.Invoice.Items)
                        {
                            <tr>
                                <td>@item.Description</td>
                                <td>@item.Quantity</td>
                                <td>@FormatCurrency(item.UnitPrice)</td>
                                <td>@FormatCurrency(item.Total)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="invoice-totals">
                <span>Subtotal <strong>@FormatCurrency(result.Invoice.Subtotal)</strong></span>
                <span>Tax <strong>@FormatCurrency(result.Invoice.TaxAmount)</strong></span>
                <span class="grand-total">Total <strong>@FormatCurrency(result.Invoice.Total)</strong></span>
            </div>
        </section>
    </div>
}
else
{
    <section class="content-panel empty-state">
        <span class="empty-mark" aria-hidden="true">JP</span>
        <h2>No results yet</h2>
        <p>Process a new job to see its professional documents here.</p>
        <a class="primary-link" href="new-job">Create a new job</a>
    </section>
}

@code {
    private static string FormatCurrency(decimal value) =>
        value.ToString("C", CultureInfo.GetCultureInfo("en-GB"));
}
