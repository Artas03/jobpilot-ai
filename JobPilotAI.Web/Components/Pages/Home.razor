@page "/"
@rendermode InteractiveServer
@using System.Globalization
@inject ApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Dashboard | JobPilotAI</PageTitle>

<section class="dashboard-hero">
    <div>
        <p class="eyebrow">Your workspace</p>
        <h1>Welcome back</h1>
        <p class="hero-copy">AI Office Assistant for Tradespeople</p>
    </div>
    <a class="primary-action" href="new-job">
        <span aria-hidden="true">+</span>
        New Job
    </a>
</section>

<section class="recent-section" aria-labelledby="recent-jobs-title">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Latest activity</p>
            <h2 id="recent-jobs-title">Recent Jobs</h2>
        </div>
    </div>

    <div class="recent-panel" aria-live="polite">
        @if (isLoading)
        {
            <div class="state-message loading-state">
                <span class="spinner" aria-hidden="true"></span>
                <span>Loading recent jobs...</span>
            </div>
        }
        else if (errorMessage is not null)
        {
            <div class="state-message error-state" role="alert">
                <strong>Recent jobs are unavailable.</strong>
                <span>@errorMessage</span>
                <button type="button" @onclick="LoadJobsAsync">Try again</button>
            </div>
        }
        else if (jobs.Count == 0)
        {
            <div class="state-message empty-state">
                <strong>No jobs completed yet.</strong>
                <span>Complete your first job to see it here.</span>
            </div>
        }
        else
        {
            <div class="jobs-table-wrapper">
                <table class="jobs-table">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Trade</th>
                            <th>Job address</th>
                            <th>Created</th>
                            <th>Invoice total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in jobs)
                        {
                            <tr class="job-row"
                                tabindex="0"
                                role="link"
                                aria-label="@($"View job for {job.CustomerName}")"
                                @onclick="() => OpenJob(job.Id)"
                                @onkeydown="eventArgs => HandleRowKeyDown(eventArgs, job.Id)">
                                <td data-label="Customer"><strong>@job.CustomerName</strong></td>
                                <td data-label="Trade"><span class="trade-label">@FormatTrade(job.TradeType)</span></td>
                                <td data-label="Job address">@(job.JobAddress ?? "Not provided")</td>
                                <td data-label="Created"><time datetime="@job.CreatedAt.ToString("O")">@FormatDate(job.CreatedAt)</time></td>
                                <td data-label="Invoice total" class="amount">
                                    @(job.InvoiceTotal.HasValue ? FormatCurrency(job.InvoiceTotal.Value) : "Not available")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@code {
    private IReadOnlyCollection<SavedJob> jobs = [];
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobsAsync();
    }

    private async Task LoadJobsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var savedJobs = await ApiClient.GetJobsAsync();
            jobs = savedJobs
                .OrderByDescending(job => job.CreatedAt)
                .ToArray();
        }
        catch (Exception exception) when (exception is HttpRequestException or TaskCanceledException or InvalidOperationException)
        {
            jobs = [];
            errorMessage = "Please check that the API is running, then try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatTrade(string tradeType) =>
        tradeType == "GeneralMaintenance" ? "General Maintenance" : tradeType;

    private static string FormatDate(DateTime createdAt) =>
        createdAt.ToLocalTime().ToString("dd MMM yyyy", CultureInfo.GetCultureInfo("en-GB"));

    private static string FormatCurrency(decimal value) =>
        value.ToString("C", CultureInfo.GetCultureInfo("en-GB"));

    private void OpenJob(Guid id)
    {
        Navigation.NavigateTo($"/jobs/{id}");
    }

    private void HandleRowKeyDown(KeyboardEventArgs eventArgs, Guid id)
    {
        if (eventArgs.Key is "Enter" or " ")
        {
            OpenJob(id);
        }
    }
}

<section class="stats-section" aria-labelledby="overview-title">
    <div class="section-heading">
        <div>
            <p class="eyebrow">At a glance</p>
            <h2 id="overview-title">Business overview</h2>
        </div>
        <span class="period-label">Today</span>
    </div>

    <div class="stats-grid">
        <article class="stat-card stat-card-jobs">
            <div class="stat-accent" aria-hidden="true"></div>
            <p>Jobs Today</p>
            <strong>0</strong>
            <span>No jobs scheduled yet</span>
        </article>
        <article class="stat-card stat-card-quotes">
            <div class="stat-accent" aria-hidden="true"></div>
            <p>Outstanding Quotes</p>
            <strong>0</strong>
            <span>All quotes are up to date</span>
        </article>
        <article class="stat-card stat-card-payment">
            <div class="stat-accent" aria-hidden="true"></div>
            <p>Awaiting Payment</p>
            <strong>&pound;0</strong>
            <span>No outstanding invoices</span>
        </article>
    </div>
</section>
